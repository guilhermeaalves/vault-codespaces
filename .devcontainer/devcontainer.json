{
  "name": "Vault Default",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "root",
  "customizations": {
    "vscode": {
      "extensions": ["hashicorp.hcl"],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteEnv": {
    "VAULT_ADDR": "http://127.0.0.1:8200",
    "VAULT_TOKEN": "root"
  },
  "postStartCommand": "bash .devcontainer/setup.sh",
  "containerEnv": {
    "SKIP_SETCAP": "true"
  },
  "forwardPorts": [8200]
}
